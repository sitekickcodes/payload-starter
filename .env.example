# ============================================
# Sitekick Starter - Environment Variables
# ============================================
#
# Option 1: 1Password CLI (recommended)
#   op inject -i .env.example -o .env.local
#
# Option 2: Manual
#   cp .env.example .env.local
#   Then fill in the values by hand
#
# The op:// references below point to your 1Password vault.
# Update the vault/item/field paths to match your setup.
# ============================================

# Payload CMS
PAYLOAD_SECRET=op://Sitekick/Starter/PAYLOAD_SECRET

# Neon Postgres
POSTGRES_URL=op://Sitekick/Starter/POSTGRES_URL

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=op://Sitekick/Starter/BLOB_READ_WRITE_TOKEN

# Google Analytics (optional — leave empty to disable)
NEXT_PUBLIC_GA_ID=
