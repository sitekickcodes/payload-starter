# ============================================
# Sitekick Payload Starter - Environment Variables
# ============================================
#
# Pull env vars with 1Password CLI:
#   bun run env:pull
#
# Or copy this file and fill in the values by hand:
#   cp .env.example .env.local
# ============================================

# Payload CMS
PAYLOAD_SECRET=op://Websites/payload-starter/PAYLOAD_SECRET
POSTGRES_URL=op://Websites/payload-starter/POSTGRES_URL
BLOB_READ_WRITE_TOKEN=op://Websites/payload-starter/BLOB_READ_WRITE_TOKEN

# Public site URL (used for metadata, sitemap, OG images)
NEXT_PUBLIC_SITE_URL=op://Websites/payload-starter/NEXT_PUBLIC_SITE_URL

# Resend (transactional email — password resets, form notifications)
RESEND_API_KEY=op://Websites/payload-starter/RESEND_API_KEY
RESEND_FROM_EMAIL=op://Websites/payload-starter/RESEND_FROM_EMAIL
FORM_NOTIFICATION_EMAIL=op://Websites/payload-starter/FORM_NOTIFICATION_EMAIL

# Anthropic (AI-generated alt text for media uploads)
ANTHROPIC_API_KEY=op://Websites/payload-starter/ANTHROPIC_API_KEY
