# ============================================
# Sitekick Starter - Environment Variables
# ============================================
# Copy this file to .env.local and fill in real values

# Payload CMS
# Generate a random secret: openssl rand -base64 32
PAYLOAD_SECRET=

# Neon Postgres (auto-set by Vercel Neon integration)
POSTGRES_URL=

# Vercel Blob Storage (auto-set by Vercel Blob integration)
BLOB_READ_WRITE_TOKEN=
