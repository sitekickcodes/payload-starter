# ============================================
# Sitekick Starter - Environment Variables
# ============================================
#
# Option 1: 1Password CLI (recommended)
#   bun run env:pull
#
# Option 2: Manual
#   cp .env.example .env.local
#   Then fill in the values by hand
#
# The op:// references below point to your 1Password vault.
# Update the item name (Client Name - Dev) to match your project.
# ============================================

# Payload CMS
PAYLOAD_SECRET=op://Environment Variables/Client Name - Dev/PAYLOAD_SECRET

# Neon Postgres
POSTGRES_URL=op://Environment Variables/Client Name - Dev/POSTGRES_URL

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=op://Environment Variables/Client Name - Dev/BLOB_READ_WRITE_TOKEN

# Public site URL (used for metadata, sitemap, OG images)
NEXT_PUBLIC_SITE_URL=op://Environment Variables/Client Name - Dev/NEXT_PUBLIC_SITE_URL

# Resend (transactional email — password resets, etc.)
RESEND_API_KEY=op://Environment Variables/Client Name - Dev/RESEND_API_KEY

# OpenAI (AI-generated alt text for media uploads)
OPENAI_API_KEY=op://Environment Variables/Client Name - Dev/OPENAI_API_KEY

# Google Analytics (optional — leave empty in 1Password to disable)
NEXT_PUBLIC_GA_ID=op://Environment Variables/Client Name - Dev/NEXT_PUBLIC_GA_ID
